{
  "name": "marko/inertia-react",
  "type": "marko-module",
  "description": "React companion for marko/inertia — configuration for React client and SSR entries",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "marko/core": "self.version",
    "marko/env": "self.version",
    "marko/inertia": "self.version",
    "marko/vite": "self.version"
  },
  "autoload": {
    "psr-4": {
      "Marko\\InertiaReact\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Marko\\InertiaReact\\Tests\\": "tests/"
    }
  },
  "extra": {
    "marko": {
      "module": true
    }
  }
}
